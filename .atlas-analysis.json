  "keyFeatures": [
    "HTTP-based durable, append-only streams",
    "Offset-based resumable reads",
    "Real-time live tailing with long-poll and SSE",
    "Idempotent producer with exactly-once delivery",
    "CDN-friendly caching and request collapsing",
    "Multi-language client libraries (10 languages)",
    "Content-type agnostic byte streams",
    "Conformance test suite for validation"
  ],
  "publicApiSurface": [
    "DurableStream.create()",
    "DurableStream.stream()",
    "DurableStream.append()",
    "IdempotentProducer",
    "StreamResponse.text()",
    "StreamResponse.json()",
    "StreamResponse.subscribe()",
    "StreamResponse.subscribeJson()",
    "PUT /stream/{path} - Create stream",
    "POST /stream/{path} - Append to stream",
    "GET /stream/{path}?offset=X - Read stream",
    "DELETE /stream/{path} - Delete stream",
    "HEAD /stream/{path} - Get metadata"
  ]
